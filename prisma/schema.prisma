generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubmissionMode {
  TEXT
  PHOTO
}

enum KnowledgePointType {
  SPELLING
  GRAMMAR
  CONTENT
  VOCABULARY
  CHINESE_ENGLISH
  EXPRESSION
  LISTENING
}

enum MasteryStatus {
  NEW
  REVIEWING
  MASTERED
}

enum UserRole {
  STUDENT
  ADMIN
}

model User {
  id          String   @id @default(cuid())
  username    String?  @unique
  passwordHash String?
  role        UserRole @default(STUDENT)
  isVip       Boolean  @default(false)
  displayName String
  email       String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exercises       ListeningExercise[]
  submissions     WritingSubmission[]
  evaluations     Evaluation[]
  knowledgePoints KnowledgePoint[]
}

model ListeningExercise {
  id              String   @id @default(cuid())
  userId          String
  title           String
  audioFileName   String
  audioStorageKey String
  audioMimeType   String
  transcript      String   @db.Text
  summary         Json
  durationSeconds Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions WritingSubmission[]

  @@index([userId, createdAt])
}

model WritingSubmission {
  id              String         @id @default(cuid())
  userId          String
  exerciseId      String
  mode            SubmissionMode
  originalText    String         @db.Text
  ocrText         String?        @db.Text
  imageStorageKey String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise   ListeningExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  evaluation Evaluation?

  @@index([userId, createdAt])
  @@index([exerciseId])
}

model Evaluation {
  id             String   @id @default(cuid())
  userId         String
  submissionId   String   @unique
  overallScore   Int
  rubricScores   Json
  overallComment String   @db.Text
  issues         Json
  sentenceNotes  Json
  improvedDraft  String   @db.Text
  contentCoverage Json
  rawModelOutput Json
  trainingReport Json?
  trainingReportGeneratedAt DateTime?
  createdAt      DateTime @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission      WritingSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  knowledgePoints KnowledgePoint[]

  @@index([userId, createdAt])
}

model KnowledgePoint {
  id               String             @id @default(cuid())
  userId           String
  evaluationId     String
  type             KnowledgePointType
  title            String
  original         String?            @db.Text
  corrected        String?            @db.Text
  explanation      String             @db.Text
  example          String?            @db.Text
  masteryStatus    MasteryStatus      @default(NEW)
  occurrenceCount  Int                @default(1)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  reviews    ReviewSession[]

  @@index([userId, type])
  @@index([userId, masteryStatus])
}

model ReviewSession {
  id               String   @id @default(cuid())
  knowledgePointId String
  prompt           String   @db.Text
  answer           String?  @db.Text
  completedAt      DateTime?
  createdAt        DateTime @default(now())

  knowledgePoint KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)
}

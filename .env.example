DATABASE_URL="postgresql://postgres:postgres@localhost:5432/en_listen_writing"

# 启动时自动创建/确保管理员账号。
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-in-local-env"

# 豆包/火山方舟：用于音频转写、音频理解、图片 OCR/视觉识别。
DOUBAO_API_KEY=""
DOUBAO_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
DOUBAO_LAS_API_KEY=""
DOUBAO_LAS_SUBMIT_URL="https://operator.las.cn-beijing.volces.com/api/v1/submit"
DOUBAO_LAS_POLL_URL="https://operator.las.cn-beijing.volces.com/api/v1/poll"
DOUBAO_LAS_OPERATOR_ID="las_asr_pro"
DOUBAO_LAS_OPERATOR_VERSION="v1"
DOUBAO_AUDIO_MODEL="doubao-seed-2-0-mini-260428"
DOUBAO_TEXT_MODEL="doubao-seed-2-0-mini-260428"
DOUBAO_VISION_MODEL="doubao-seed-2-0-mini-260428"

# 局域网 STT Wrapper：优先用于音频转写，支持直接上传文件，不需要公网音频 URL。
STT_WRAPPER_BASE_URL="http://192.168.2.213:27178"
STT_WRAPPER_TRANSCRIBE_PATH="/stt/transcribe"
STT_WRAPPER_MODEL="Systran/faster-whisper-small"
STT_WRAPPER_API_KEY=""

# DeepSeek：用于作文批改、知识点抽取、复习题生成。
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-flash"

# 本地开发可用于 OCR/批改等非真实链路兜底；音频不会再用假 transcript 冒充真实内容。
AI_MOCK_FALLBACK="true"

# 真实豆包 LAS 录音文件识别需要公网 HTTPS 音频地址。
# 本地开发可保持 mock；部署后填写应用公网域名或改为 TOS 对象存储 URL。
APP_PUBLIC_BASE_URL=""

# 本地文件存储目录。生产环境建议替换为对象存储。
UPLOAD_ROOT="./uploads"
